# ============================================================
# Oracle Forge — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── LLM API Keys (at least one required) ──────────────────
# Option A: Direct Anthropic API (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenRouter (supports Claude + other models)
OPENROUTER_API_KEY=sk-or-...

# Option C: Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-08-01-preview

# Option D: Gemini
GEMINI_API_KEY=

# ── LLM Model ─────────────────────────────────────────────
# Default model to use. Options:
#   claude-opus-4-6        (best quality, higher cost)
#   claude-sonnet-4-6      (balanced)
#   gemini-3-pro           (via Gemini API)
DEFAULT_LLM=claude-opus-4-6

# ── PostgreSQL ─────────────────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=oracleforge
PG_DB=postgres
PG_CLIENT=psql

# ── MongoDB ────────────────────────────────────────────────
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=oracle
MONGO_PASSWORD=oracleforge
MONGO_URI=mongodb://oracle:oracleforge@mongodb:27017/

# ── Paths ──────────────────────────────────────────────────
DAB_ROOT=/app/DataAgentBench
KB_ROOT=/app/kb

# ── Agent Tuning ───────────────────────────────────────────
MAX_ITERATIONS=100
MAX_RETRIES=2
EXEC_PYTHON_TIMEOUT=600

# ── Cloudflare Workers Sandbox (optional alternative) ──────
# SANDBOX_URL=https://sandbox.your-team.workers.dev
